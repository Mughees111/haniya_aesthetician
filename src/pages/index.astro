---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeRoute from '../react/routes/HomeRoute';
import { siteConfig } from '../config/siteConfig';
import { getHomeSchemaJson } from '../seo/homeSchema';
import { resolveAsset } from '../utils/resolveAsset';

const title =
  'Ghadia Haider | Professional Aesthetician Lahore — Botox, Fillers, PRP & Laser';
const description =
  'Lahore aesthetician Ghadia Haider — 4+ years in Botox, dermal fillers, PRP, laser & skin rejuvenation. Natural results, DHA & Gulberg clients, clinic collaborations. Book via WhatsApp.';
const keywords = `${siteConfig.seo.keywords}, aesthetician DHA Lahore, Botox Gulberg, best filler injector Lahore`;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={resolveAsset(siteConfig.personal.image)}
  schemaJson={getHomeSchemaJson()}
>
  <HomeRoute client:load currentPath={Astro.url.pathname} />
</BaseLayout>
