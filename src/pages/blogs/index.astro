---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogRoute from '../../react/routes/BlogRoute';
import { siteConfig } from '../../config/siteConfig';
import { getBlogListSchemaJson } from '../../seo/blogListSchema';

const title = 'Aesthetics Blog | Expert Guides by Ghadia Haider — Lahore Aesthetician';
const description =
  'In-depth guides on Botox, dermal fillers, PRP, laser, bridal skin prep, anti-aging for South Asian skin, and at-home aesthetic treatments in Lahore — by professional aesthetician Ghadia Haider.';
const keywords = `aesthetics blog Lahore, bridal skin prep Pakistan, anti-aging South Asian skin, at home aesthetic treatments Lahore, Botox aftercare Pakistan, filler guide Lahore, PRP blog, laser skin blog 2026, ${siteConfig.seo.keywords}`;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  schemaJson={getBlogListSchemaJson()}
>
  <BlogRoute client:load currentPath={Astro.url.pathname} />
</BaseLayout>
